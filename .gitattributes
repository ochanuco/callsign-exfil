# Default: normalize line endings for text
* text=auto

# Source code: explicit text
*.cpp text
*.h   text
*.cs  text
*.ini text
*.md  text
*.txt text
*.json text
*.yaml text
*.yml  text
*.uplugin text
*.uproject text
*.Target.cs text
*.Build.cs text

# Unreal binary asset/map: LFS + binary
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap   filter=lfs diff=lfs merge=lfs -text

# Source art / audio / video / model: LFS + binary
*.fbx  filter=lfs diff=lfs merge=lfs -text
