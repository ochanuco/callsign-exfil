# macOS
.DS_Store
._*
.AppleDouble
.LSOverride

# Local workspace (per global rules)
.local/

# Editors / IDEs
.vscode/
.idea/
.vs/
*.swp
*.swo

# Unreal Engine generated directories (any depth)
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/
Script/
Plugins/*/Binaries/
Plugins/*/Intermediate/

# Unreal Engine generated project files
*.VC.db
*.opensdf
*.opendb
*.sdf
*.sln
*.suo
*.xcodeproj/
*.xcworkspace/

# Unreal Engine logs and crashes
*.log
*.dmp
*.dump
CrashReportClient.ini

# Visual Studio Code workspace files generated by UE
.ue4-vsconfig
compile_commands.json

# Node / tooling (if we add scripts later)
node_modules/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Env / secrets
.env
.env.local
.env.*
!.env.example
*.pem
*.key
